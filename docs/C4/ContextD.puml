@startuml C4_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

hide stereotype
SHOW_PERSON_OUTLINE()
left to right direction

title Диаграмма контекста — Система «Красные флажки»

Person(user, "Пользователь", "Физическое лицо, желающее проверить договор или иной юридический документ на наличие рисков перед его подписанием.")
Person(admin, "Администратор", "Сотрудник, ответственный за наполнение базы знаний: загружает и актуализирует шаблоны «красных флажков», подготовленные юристами.")

System(red_flags, "Красные флажки", "Платформа автоматического анализа юридических документов. Выявляет потенциальные риски («красные флажки') и формирует отчёт на понятном пользователю языке.")

System_Ext(payment_system,  "Платёжный сервис", "Российская платёжная система. Обрабатывает транзакции при переходе пользователя на платный тарифный план." )

Rel(user, red_flags, "Выполняет проверку документа, используя", "Telegram Bot")
Rel(admin, red_flags, "Выполняет загрузку шаблонов «красных флажков», используя", "Jupyter Notebook")
Rel(red_flags, payment_system, "Передаёт информацию о платёжной транзакции в", "HTTPS / API")
Rel(payment_system, red_flags, "Передаёт информацию о результате оплаты в", "HTTPS / Webhook")

@enduml