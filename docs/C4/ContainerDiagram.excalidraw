      "type": "text",
      "x": 1694.355332474861,
      "y": 163.94160095502218,
      "width": 322.6019368711949,
      "height": 95.4379633470474,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ff8787",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
