      "x": 1998.1257805822374,
      "y": 1408.2063448103759,
      "width": 314.202234220669,
      "height": 95.4379633470474,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ff8787",
